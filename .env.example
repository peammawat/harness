# ---------------------------------------------------------------------------
# Onebix Harness — configuration
# Copy this file to `.env` and fill in the keys you have. Any provider whose
# key is missing is simply skipped; the rest of the system keeps working.
# ---------------------------------------------------------------------------

# --- External API authentication ---
# Comma-separated list of API keys clients must send via the `X-API-Key` header.
# Generate one with:  python -c "import secrets; print('sk-harness-'+secrets.token_urlsafe(32))"
API_KEYS=sk-harness-changeme

# --- Web login (username + password) ---
# Comma-separated "user:password" pairs. These are a ONE-TIME SEED: on first
# boot each becomes a DB user row (idempotent — re-seeding never overwrites a
# password later changed in the admin panel). Manage users afterwards in the
# panel. Empty = no seed (programmatic X-API-Key access still works).
AUTH_USERS=alice:changeme
# Comma-separated usernames seeded with the "admin" role (gain the admin panel).
ADMIN_USERS=alice
# PBKDF2 iterations for hashing user passwords in the DB.
PBKDF2_ITERATIONS=200000
# Secret used to sign session tokens. Set a long random value in production.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET=change-me
# Session lifetime in seconds (default 7 days).
AUTH_TOKEN_TTL_SECONDS=604800

# --- Chat history (per-user conversation persistence) ---
# Stored in SQLite, partitioned by the authenticated identity. Set false to keep
# the API stateless (chat still works; the /v1/conversations endpoints 404).
CHAT_HISTORY_ENABLED=true
CHAT_DB_PATH=data/chat_history.db

# --- Defaults ---
DEFAULT_LLM_PROVIDER=anthropic        # anthropic | openai | local
DEFAULT_SEARCH_BACKEND=duckduckgo     # searxng|brave|tavily|serper|perplexity|google|duckduckgo
DEFAULT_ANTHROPIC_MODEL=claude-opus-4-8
DEFAULT_OPENAI_MODEL=gpt-4o
MAX_TOKENS=16000
# Tool-use loop budget: how many tool round-trips before the model must answer.
# Raise these if you hit "step limit" on complex tasks.
MAX_ITERATIONS=6
DEEP_RESEARCH_ITERATIONS=16

# --- LLM provider keys ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# "local" provider reuses the OpenAI client against an OpenAI-compatible server
# (Ollama, vLLM, LM Studio, ...). Leave blank to disable.
LOCAL_OPENAI_BASE_URL=http://localhost:11434/v1
LOCAL_OPENAI_API_KEY=not-needed
LOCAL_MODEL=llama3.1
# Set true only if LOCAL_MODEL is vision-capable (e.g. Qwen-VL, LLaVA) and the
# server accepts OpenAI-style image_url content; otherwise images are dropped
# with a text note so non-vision models don't error.
LOCAL_SUPPORTS_VISION=false

# --- Search provider keys ---
SEARXNG_URL=http://localhost:8080
BRAVE_API_KEY=
TAVILY_API_KEY=
SERPER_API_KEY=
PERPLEXITY_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# --- HTTP ---
REQUEST_TIMEOUT=30

# --- Attachments (inline base64 in the chat request) ---
MAX_REQUEST_BYTES=26214400            # reject chat bodies larger than this (~25 MB)
MAX_DOCUMENT_CHARS=50000              # extracted-text cap per attached document
ALLOWED_IMAGE_TYPES=image/png,image/jpeg,image/webp,image/gif
ALLOWED_DOCUMENT_TYPES=application/pdf,text/plain,text/markdown,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# --- fetch_url tool (used by link insertion + deep research) ---
FETCH_TIMEOUT=15
FETCH_MAX_BYTES=2097152               # cap downloaded bytes per page (~2 MB)
FETCH_MAX_CHARS=40000                 # cap text returned to the model
FETCH_USER_AGENT=OnebixHarness/0.1 (+fetch_url)
FETCH_BLOCK_PRIVATE_IPS=true          # SSRF guard: refuse private/internal hosts
